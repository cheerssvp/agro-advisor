# Get a free Gemini API key at https://aistudio.google.com/apikey
GOOGLE_API_KEY=your-gemini-api-key-here

# Optional: free API key from https://www.data.gov.in (sign up, instant approval)
# for LIVE government mandi prices (Agmarknet data). If unset, market_agent falls
# back to the bundled sample dataset (mcp_server/market_data.csv).
DATA_GOV_API_KEY=your-data-gov-in-api-key-here

# Optional: free LangSmith API key (https://smith.langchain.com -> Settings ->
# API Keys) for trace observability. If unset, no tracing happens -- the app
# runs identically either way. Sends ADK's built-in OpenTelemetry spans to
# LangSmith over OTLP; no langsmith SDK or LangChain dependency needed.
LANGSMITH_API_KEY=your-langsmith-api-key-here
LANGSMITH_PROJECT=agro-advisor

# Optional overrides
GEMINI_MODEL=gemini-2.5-flash


